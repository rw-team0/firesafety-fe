# 이 파일을 복사해 .env(.local)로 만들고 실제 값을 채우세요. .env 자체는 Git에 커밋하지 않습니다.

# 백엔드 API 주소 (vite.config.js 프록시 target으로 사용 예정)
VITE_API_BASE_URL=http://192.168.0.31:8080

# FCM 웹푸시(모바일 PWA 전용, NFR-11) — Firebase 콘솔의 웹 앱 설정값
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_VAPID_KEY=
